<Window x:Class="AdminApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin belépés"
        Height="220"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Admin belépés"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <PasswordBox x:Name="PasswordBox"
                         Height="35"
                         FontSize="14"
                         Margin="0,0,0,10"/>

            <TextBlock x:Name="ErrorText"
                       Text="Hibás jelszó!"
                       Foreground="Red"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="1"
                Content="Belépés"
                Height="35"
                Click="Login_Click"/>
    </Grid>
</Window>